 * SPDX-License-Identifier: MIT
 *
 * Redirect the Zephyr console from uart0 (GPIO43/44 -> USB-UART bridge ->
 * ttyUSB0) to the built-in USB-JTAG CDC-ACM interface (ttyACM0) so that
 * test output is visible on a single USB cable without needing the separate
 * UART bridge port.
 *
 * The board DTS disables usb_serial by default; re-enable it here.
 */

&usb_serial {
	status = "okay";
};

/ {
	chosen {
		zephyr,console = &usb_serial;
		zephyr,shell-uart = &usb_serial;
	};
};
